# geoboundary configuration
# Copy this file to .env and fill in your values

# Optional: Amap (高德) API key
# Get a free key at https://lbs.amap.com/dev/key
AMAP_API_KEY=

# Optional: Custom Overpass API endpoint
# Default: https://overpass-api.de/api/interpreter
OVERPASS_URL=

# Optional: Request delay in seconds (avoid rate limiting)
# Default: 2
REQUEST_DELAY=

# Optional: User-Agent string for HTTP requests
USER_AGENT=
